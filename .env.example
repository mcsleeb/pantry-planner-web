# ============================================================================
#  Pantry Planner — environment variables
#
#  Copy this file to .env.local and fill in the values.
#  .env.local is gitignored, so your real keys never get committed.
# ============================================================================

# ---- Supabase (required) --------------------------------------------------
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Server-only key. NEVER expose this in client code.
# Same page as above, labeled "service_role" key.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ---- Spoonacular (required for recipe import + price estimation) ----------
# Get a free key at: https://spoonacular.com/food-api/console
# Server-side only — clients never see this.
SPOONACULAR_API_KEY=your-key-here

# ---- App config -----------------------------------------------------------
# The publicly accessible URL for redirects (e.g. after email verification).
# Leave as http://localhost:3000 for dev; Vercel sets this automatically in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000
